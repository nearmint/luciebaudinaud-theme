# .env.example — Template pour le déploiement SFTP OVH
# Copier ce fichier vers .env (gitignored) et remplir les vraies valeurs.
# NE JAMAIS committer .env (contient le mot de passe SFTP).

# OVH SFTP credentials (cf. manager OVH > Web Cloud > Hosting > FTP-SSH)
SFTP_HOST=ftp.cluster111.hosting.ovh.net
SFTP_USER=your_user_here
SFTP_PORT=22
SFTP_PASSWORD=your_password_here

# Path destination côté serveur OVH (LOWERCASE, Linux case-sensitive)
SFTP_REMOTE_PATH=www/wp-content/themes/lb3

# Path source local (le dossier du thème courant)
LOCAL_THEME_PATH=.
