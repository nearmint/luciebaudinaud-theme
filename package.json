{
  "name": "luciebaudinaud-theme",
  "version": "1.0.0",
  "private": true,
  "description": "Custom WordPress theme for cinematographer Lucie Baudinaud (AFC)",
  "license": "MIT",
  "author": "Nicolas Rapp <https://www.nicolasrapp.co>",
  "homepage": "https://github.com/nearmint/luciebaudinaud-theme#readme",
  "bugs": {
    "url": "https://github.com/nearmint/luciebaudinaud-theme/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nearmint/luciebaudinaud-theme.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/js",
    "lint:fix": "eslint src/js --fix",
    "format": "prettier --write \"**/*.{js,ts,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,css,json,md}\"",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.6",
    "lint-staged": "^17.0.5",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.1.14",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "@alpinejs/intersect": "^3.14.9",
    "@fontsource/montserrat": "^5.1.1",
    "@fontsource/quicksand": "^5.1.1",
    "alpinejs": "^3.14.9",
    "photoswipe": "^5.4.4",
    "web-vitals": "^4.2.4"
  },
  "lint-staged": {
    "*.php": "php -l",
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.ts": "prettier --write",
    "*.{css,json,md}": "prettier --write"
  }
}
